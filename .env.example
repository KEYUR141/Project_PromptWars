# ─────────────────────────────────────────────
# VenueIQ — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# Required: Gemini API key from Google AI Studio
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Google Maps JavaScript API key
# Enable "Maps JavaScript API" in Google Cloud Console
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Required: Flask session secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_random_secret_key_here

# Optional: Flask environment (development | production)
FLASK_ENV=production
